# Use flat node_modules layout instead of pnpm's default symlink farm.
# Reasons:
#   - Windows runners frequently can't create per-package .bin symlinks,
#     causing `tsc not found` errors during `pnpm exec tsc` in workspace
#     packages. Hoisted flat layout puts tsc at node_modules/.bin once.
#   - Tooling that assumes npm-style flat node_modules (some CI utilities,
#     editors, certain code generators) Just Works.
# Trade-off: a package could accidentally depend on a transitive without
# declaring it. Acceptable for this monorepo; CI build catches it.
node-linker=hoisted

# Hoist EVERY transitive dep (not just direct) to the root node_modules.
# Equivalent to the legacy --shamefully-hoist flag. Required because
# packages reference binaries (tsc, vite) without declaring them as
# direct deps; with isolated/strict hoisting those binaries aren't
# visible to `pnpm exec` from inside a workspace package on Windows.
public-hoist-pattern[]=*

# Ensure pnpm uses a junction (Windows-friendly) when symlinks would
# otherwise need privileged perms.
symlink=true
prefer-symlinked-executables=false
